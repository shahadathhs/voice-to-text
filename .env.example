# =============================================================================
# Voice-to-Text Environment Configuration
# =============================================================================
# Copy this file to .env and update with your settings

# =============================================================================
# Application Settings
# =============================================================================
APP_NAME=Voice-to-Text API
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# =============================================================================
# Server Configuration
# =============================================================================
HOST=0.0.0.0
PORT=8000
WORKERS=1
API_PREFIX=

# API base URL (optional, for constructing full URLs in responses)
# If not set, URLs will be auto-detected from the request
# Examples: http://localhost:8000, https://api.example.com
# API_HOST=

# =============================================================================
# Media Configuration
# =============================================================================
# Media directory (contains audio/, uploads/, and transcripts/ subdirectories)
MEDIA_DIR=media

# Default audio input directory (for CLI usage, relative to MEDIA_DIR)
AUDIO_DIR=media/audio

# Uploaded audio files directory (for API usage, relative to MEDIA_DIR)
UPLOADS_DIR=media/uploads

# Transcript output directory (relative to MEDIA_DIR)
TRANSCRIPT_DIR=media/transcripts

# Model cache directory
MODEL_CACHE_DIR=model-cache

# =============================================================================
# Whisper Configuration
# =============================================================================
# Default model size: tiny, base, small, medium, large
WHISPER_MODEL=base

# Whisper backend: openai (default) or transformers
WHISPER_BACKEND=openai

# Device: cpu or cuda
WHISPER_DEVICE=cpu

# =============================================================================
# Feature Flags
# =============================================================================
# Enable translation to English
ENABLE_TRANSLATION=false

# Enable speaker diarization
ENABLE_DIARIZATION=false

# =============================================================================
# Diarization Settings (SpeechBrain)
# =============================================================================
# Clustering threshold (0.0-1.0, lower = more speakers)
DIARIZE_THRESHOLD=0.35

# Maximum number of speakers (null = auto-detect)
# MAX_SPEAKERS=2

# Use silhouette analysis to estimate speaker count
USE_SILHOUETTE=false

# =============================================================================
# API Configuration
# =============================================================================
# Maximum file size (in bytes)
MAX_FILE_SIZE=524288000

# Allowed audio formats (comma-separated)
ALLOWED_FORMATS=wav,mp3,ogg,m4a,flac,aac

# =============================================================================
# Security Settings
# =============================================================================
# Secret key for API authentication
SECRET_KEY=your-secret-key-change-in-production

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# =============================================================================
# Docker Settings
# =============================================================================
PACKAGE_NAME=voice-to-text
DOCKER_REGISTRY=shahadathhs
