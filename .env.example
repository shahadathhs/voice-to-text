# =============================================================================
# Voice-to-Text Environment Configuration
# =============================================================================
# Copy this file to .env and update with your settings

# =============================================================================
# Application Settings
# =============================================================================
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# =============================================================================
# API Settings
# =============================================================================
HOST=0.0.0.0
PORT=8000
WORKERS=4

# =============================================================================
# Transcription Settings
# =============================================================================
# Default model size: tiny, base, small, medium, large
WHISPER_MODEL=base

# Whisper backend: openai (default) or transformers
WHISPER_BACKEND=openai

# Device: cpu or cuda
WHISPER_DEVICE=cpu

# Language (auto-detect if not set)
# WHISPER_LANGUAGE=en

# Task: transcribe or translate
WHISPER_TASK=transcribe

# =============================================================================
# Model Cache Settings
# =============================================================================
# Cache directory for Whisper models
MODEL_CACHE_DIR=/root/.cache

# =============================================================================
# File Processing Settings
# =============================================================================
# Media directory (contains audio/ and transcripts/ subdirectories)
MEDIA_DIR=/app/media

# Audio input directory (relative to MEDIA_DIR)
AUDIO_DIR=/app/media/audio

# Transcript output directory (relative to MEDIA_DIR)
TRANSCRIPT_DIR=/app/media/transcripts

# Maximum file size (in MB)
MAX_FILE_SIZE=500

# Allowed audio formats
ALLOWED_FORMATS=wav,mp3,ogg,m4a,flac

# =============================================================================
# Security Settings
# =============================================================================
# Secret key for API authentication (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=your-secret-key-here-change-in-production

# API key requirement (true/false)
REQUIRE_API_KEY=false

# =============================================================================
# Diarization Settings (SpeechBrain)
# =============================================================================
# Enable speaker diarization
ENABLE_DIARIZATION=false

# Number of speakers (auto-detect if not set)
# NUM_SPEAKERS=2

# =============================================================================
# Translation Settings
# =============================================================================
# Enable translation to English
ENABLE_TRANSLATION=false

# Target language for translation
TRANSLATION_TARGET_LANGUAGE=en
